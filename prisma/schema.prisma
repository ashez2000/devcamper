generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PUBLISHER
  ADMIN
}

enum Skill {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bootcamp Bootcamp[]
  Course   Course[]
  Review   Review[]
}

model Bootcamp {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String
  website     String
  phone       String
  email       String
  address     String
  careers     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User     @relation(fields: [userId], references: [id])
  userId String
  Course Course[]
  Review Review[]
}

model Course {
  id                    String  @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  description           String
  weeks                 Int
  tuition               Int
  minimumSkill          Skill
  scholarshipsAvailable Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String

  bootcamp   Bootcamp @relation(fields: [bootcampId], references: [id])
  bootcampId String
}

model Review {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  title  String
  text   String
  rating Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String

  bootcamp   Bootcamp @relation(fields: [bootcampId], references: [id])
  bootcampId String
}
