generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Bootcamp {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String @unique
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
