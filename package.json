{
  "name": "devcamper-api",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nodemon -r tsconfig-paths/register src/main.ts",
    "build": "prisma db push && tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "prisma": "prisma db push",
    "data:import": "ts-node seeder/main.ts",
    "data:destroy": "ts-node seeder/main.ts -d"
  },
  "dependencies": {
    "@prisma/client": "^4.11.0",
    "argon2": "^0.30.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.3",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@tsconfig/node18": "^2.0.1",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/hpp": "^0.2.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/nodemailer": "^6.4.8",
    "nodemon": "^2.0.22",
    "prisma": "^4.15.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.6",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "author": "Aswin Gangadharan",
  "license": "MIT"
}
