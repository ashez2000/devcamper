{
  "name": "devcamper-api",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "tsup src/main.ts --format cjs --watch --onSuccess \"node dist/main.js\"",
    "build": "tsup src/main.ts --format cjs",
    "data:import": "tsx seeder/main.ts",
    "data:destroy": "tsx seeder/main.ts -d"
  },
  "dependencies": {
    "argon2": "^0.30.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "node-geocoder": "^4.2.0",
    "nodemailer": "^6.9.3",
    "ramda": "^0.29.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@tsconfig/node18": "^2.0.1",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/hpp": "^0.2.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node-geocoder": "^4.2.1",
    "@types/nodemailer": "^6.4.8",
    "@types/ramda": "^0.29.3",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "tsup": "^7.1.0",
    "tsx": "^3.12.7",
    "typescript": "^5.2.2"
  }
}
