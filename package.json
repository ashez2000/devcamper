{
  "name": "devcamper-api",
  "version": "1.0.0",
  "description": "Devcamper API is a backend service for online educational bootcamps.",
  "type": "commonjs",
  "volta": {
    "node": "18.15.0"
  },
  "scripts": {
    "start": "node dist/main.js",
    "build": "rimraf dist && swc ./src -d dist",
    "dev": "nodemon --exec ts-node src/main.ts",
    "seed": "ts-node ./prisma/seed/seeder.ts",
    "seed:d": "ts-node ./prisma/seed/seeder.ts -d"
  },
  "dependencies": {
    "@prisma/client": "^4.11.0",
    "argon2": "^0.28.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.0.1",
    "express-rate-limit": "^6.5.1",
    "helmet": "^5.1.1",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "prisma": "^4.11.0",
    "swagger-jsdoc": "^6.2.5",
    "swagger-ui-express": "^4.5.0",
    "zod": "^3.19.1"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.46",
    "@tsconfig/node18": "^1.0.1",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/hpp": "^0.2.2",
    "@types/jsonwebtoken": "^8.5.8",
    "@types/morgan": "^1.9.3",
    "@types/node": "^18.15.11",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "eslint": "^8.37.0",
    "nodemon": "^2.0.7",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.3"
  },
  "author": "Aswin Gangadharan",
  "license": "MIT"
}
